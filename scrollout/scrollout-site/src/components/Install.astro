---
import Dots from './Dots.astro';

const steps = [
  {
    num: '01',
    color: 'var(--color-bleu-ciel)',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>',
    title: 'Autorise les sources inconnues',
    text: 'Ouvre <strong>Paramètres > Sécurité</strong> sur ton téléphone et active <strong>Sources inconnues</strong> (ou "Installer des applis inconnues" pour ton navigateur). Android bloque par défaut les applis hors Play Store.',
  },
  {
    num: '02',
    color: 'var(--color-bleu-indigo)',
    textColor: 'white',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
    title: 'Télécharge l\u2019APK',
    text: 'Clique sur le bouton ci-dessous depuis ton téléphone Android. Le fichier <code>scrollout-latest.apk</code> se télécharge directement.',
    cta: true,
  },
  {
    num: '03',
    color: 'var(--color-vert-menthe)',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    title: 'Installe et active',
    text: 'Ouvre le fichier téléchargé, accepte l\u2019installation, puis lance Scrollout. L\u2019app te guide pour activer le <strong>service d\u2019accessibilité</strong> — c\u2019est ce qui permet de lire ce qu\u2019Instagram te montre.',
  },
  {
    num: '04',
    color: 'var(--color-orange)',
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
    title: 'Scrolle normalement',
    text: 'Ouvre Instagram et utilise-le comme d\u2019habitude. Scrollout capture en arrière-plan. Reviens dans l\u2019app quand tu veux voir ton rapport.',
  },
];

const apkUrl = 'https://gitlab.com/api/v4/projects/tordu-jardin%2Fechafaud/packages/generic/scrollout-apk/latest/scrollout-latest.apk';
---

<section id="installer" class="install">
  <span class="section-label mono">Installer Scrollout</span>

  <div class="install-intro" data-reveal>
    <p>Scrollout n'est pas sur le Play Store. C'est volontaire&nbsp;: pas de tracking, pas de compte Google, pas de conditions.</p>
  </div>

  <Dots />

  <div class="install-steps" data-stagger>
    {steps.map((s, i) => (
      <div class="step">
        <div class="step-header">
          <div class="step-icon" style={`background: ${s.color}; ${s.textColor ? `color: ${s.textColor}` : ''}`}>
            <Fragment set:html={s.icon} />
          </div>
          {i < steps.length - 1 && (
            <div class="step-connector">
              <div class="step-connector-fill"></div>
            </div>
          )}
        </div>
        <div class="step-content">
          <div class="step-num mono">{s.num}</div>
          <h3>{s.title}</h3>
          <p set:html={s.text} />
          {s.cta && (
            <a href={apkUrl} class="btn btn-black install-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Télécharger l'APK
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="install-note" data-reveal>
    <p class="mono">Android 8+ requis · ~27 Mo · Aucune donnée collectée</p>
  </div>
</section>

<style>
  .install {
    padding: 100px 24px;
    max-width: var(--container-width);
    margin: 0 auto;
  }

  .install-intro {
    max-width: 600px;
    margin-bottom: 8px;
  }

  .install-intro p {
    font-size: 1.15rem;
    color: var(--text-grey);
    line-height: 1.7;
  }

  .install-steps {
    margin-top: 48px;
  }

  .step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 28px;
    min-height: 140px;
  }

  .step-header {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .step-icon {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    transition: transform 0.4s var(--ease-out-back), box-shadow 0.4s ease;
  }

  .step:hover .step-icon {
    transform: scale(1.1) rotate(-4deg);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .step-connector {
    width: 2px;
    flex: 1;
    background: #EEE;
    margin: 8px 0;
    position: relative;
    overflow: hidden;
    border-radius: 1px;
  }

  .step-connector-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, var(--color-bleu-indigo), transparent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1.2s var(--ease-out-expo);
  }

  .install-steps.revealed .step-connector-fill {
    transform: scaleY(1);
  }

  .step-content {
    padding-bottom: 32px;
  }

  .step-num {
    font-size: 0.65rem;
    color: var(--text-grey);
    margin-bottom: 4px;
    opacity: 0.5;
  }

  .step-content h3 {
    font-size: 1.6rem;
    margin-bottom: 10px;
  }

  .step-content p {
    font-size: 1.05rem;
    color: var(--text-grey);
    line-height: 1.7;
    max-width: 560px;
  }

  .step-content :global(code) {
    background: #F0F0F0;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', monospace;
  }

  .install-btn {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .install-note {
    margin-top: 48px;
    text-align: center;
  }

  .install-note p {
    color: var(--text-grey);
    font-size: 0.75rem;
  }

  @media (max-width: 640px) {
    .install {
      padding: 60px 16px;
    }

    .step {
      grid-template-columns: 52px 1fr;
      gap: 20px;
    }

    .step-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
    }

    .step-icon :global(svg) {
      width: 18px;
      height: 18px;
    }

    .step-content h3 {
      font-size: 1.3rem;
    }

    .step-content p {
      font-size: 0.95rem;
    }

    .install-intro p {
      font-size: 1rem;
    }
  }
</style>
