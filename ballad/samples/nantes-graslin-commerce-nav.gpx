<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="HikeBuddy"
     xmlns="http://www.topografix.com/GPX/1/1"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">

  <metadata>
    <name>Place Graslin → Place Royale</name>
    <desc>Walk through central Nantes with navigation instructions</desc>
    <author>
      <name>HikeBuddy</name>
    </author>
    <time>2026-03-28T12:00:00Z</time>
  </metadata>

  <!-- Navigation waypoint at midpoint -->
  <wpt lat="47.16871" lon="-1.56048">
    <ele>8</ele>
    <name>Continue south toward Place Royale</name>
    <desc>Keep heading south. Place Royale is approximately 5km ahead.</desc>
    <cmt>Navigation: continue south</cmt>
    <sym>Flag, Blue</sym>
  </wpt>

  <rte>
    <name>Graslin to Royale</name>
    <rtept lat="47.21299" lon="-1.56224">
      <ele>10</ele>
      <name>Place Graslin</name>
      <desc>Start — Head south from Place Graslin</desc>
    </rtept>
    <rtept lat="47.19085" lon="-1.56136">
      <ele>9</ele>
      <name>Intermediate (north)</name>
    </rtept>
    <rtept lat="47.16871" lon="-1.56048">
      <ele>8</ele>
      <name>Midpoint</name>
    </rtept>
    <rtept lat="47.14656" lon="-1.55960">
      <ele>7</ele>
      <name>Intermediate (south)</name>
    </rtept>
    <rtept lat="47.12442" lon="-1.55872">
      <ele>6</ele>
      <name>Place Royale</name>
      <desc>End — You have arrived at Place Royale</desc>
    </rtept>
  </rte>

  <trk>
    <name>Graslin to Royale</name>
    <trkseg>
      <trkpt lat="47.21299" lon="-1.56224"><ele>10</ele></trkpt>
      <trkpt lat="47.19085" lon="-1.56136"><ele>9</ele></trkpt>
      <trkpt lat="47.16871" lon="-1.56048"><ele>8</ele></trkpt>
      <trkpt lat="47.14656" lon="-1.55960"><ele>7</ele></trkpt>
      <trkpt lat="47.12442" lon="-1.55872"><ele>6</ele></trkpt>
    </trkseg>
  </trk>

</gpx>
