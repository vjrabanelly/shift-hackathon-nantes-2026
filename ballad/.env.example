OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...

# TTS provider
TTS_PROVIDER=mistral
# Voix Mistral (UUIDs) — toutes en_us/en_gb mais multilingues
# Paul - Neutral : c69964a6-ab8b-4f8a-9465-ec0925096ec8 (défaut)
# Paul - Cheerful: 01d985cd-5e0c-4457-bfd8-80ba31a5bc03
