MISTRAL_VOICE=c69964a6-ab8b-4f8a-9465-ec0925096ec8

# Optionnel
PORT=8081
OPENAI_MODEL=gpt-4.1-mini
OVERPASS_ENDPOINTS=https://overpass-api.de/api/interpreter,https://overpass.openstreetmap.ru/api/interpreter,https://lz4.overpass-api.de/api/interpreter,https://z.overpass-api.de/api/interpreter,https://overpass.private.coffee/api/interpreter,https://overpass.kumi.systems/api/interpreter
